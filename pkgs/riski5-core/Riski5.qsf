# SPDX-FileCopyrightText: 2026 Mika Tammi
# SPDX-License-Identifier: MIT OR BSD-3-Clause
#
# Quartus II 13.0sp1 settings for riski5 on the Altera DE2
# (Cyclone II EP2C35F672C6).
#
# Pin assignments are taken verbatim from the Terasic DE2 User Manual
# v1.6 (2012-10-08), tables 4.1–4.6, pinned at
#   docs/de2/DE2_UserManual_v1.6_2012-10-08.pdf
# in this repo. Pages 14–15 (LEDs / KEYs / SWs) and page 35 (LCD).

set_global_assignment -name FAMILY "Cyclone II"
set_global_assignment -name DEVICE EP2C35F672C6
# riski5_top wraps the Clash-emitted riski5 module with the bidirectional
# SRAM_DQ resolution (Clash exposes _O / _OE / _I; the wrapper produces a
# single inout pin). The wrapper is generated inline by package.nix.
set_global_assignment -name TOP_LEVEL_ENTITY riski5_top
set_global_assignment -name ORIGINAL_QUARTUS_VERSION "13.0 SP1"
set_global_assignment -name LAST_QUARTUS_VERSION "13.0 SP1"
set_global_assignment -name STRATIX_DEVICE_IO_STANDARD "3.3-V LVTTL"
set_global_assignment -name RESERVE_ALL_UNUSED_PINS "AS INPUT TRI-STATED"

# -- Synthesis optimization ----------------------------------------
# Push for fmax over area. The pipelineless single-cycle core has
# the entire datapath in one clock period; aggressive synthesis
# lets Quartus trade LE area for path delay.
set_global_assignment -name OPTIMIZATION_TECHNIQUE SPEED
set_global_assignment -name FITTER_EFFORT "STANDARD FIT"
set_global_assignment -name PHYSICAL_SYNTHESIS_COMBO_LOGIC ON
set_global_assignment -name PHYSICAL_SYNTHESIS_REGISTER_DUPLICATION ON
set_global_assignment -name PHYSICAL_SYNTHESIS_REGISTER_RETIMING ON
set_global_assignment -name PHYSICAL_SYNTHESIS_EFFORT EXTRA

# -- Source files --------------------------------------------------
# Clash emits ./verilog/Top.topEntity/riski5.v on each build.
set_global_assignment -name VERILOG_FILE verilog/Top.topEntity/riski5.v
set_global_assignment -name SDC_FILE Riski5.sdc

# -- Clocks --------------------------------------------------------
# Two on-board oscillators feed the two ALTPLL instances (task #141):
#   CLOCK_50 (PIN_N2) → u_altpll → clkBus + clkCore at 40 MHz
#   CLOCK_27 (PIN_D13) → u_altpll_sdram → clkSdram + clkSdramOut at
#                                          30 MHz (input × 10/9)
set_location_assignment PIN_N2 -to CLOCK_50
set_instance_assignment -name IO_STANDARD "3.3-V LVTTL" -to CLOCK_50
set_location_assignment PIN_D13 -to CLOCK_27
set_instance_assignment -name IO_STANDARD "3.3-V LVTTL" -to CLOCK_27

# Per DE2 User Manual §4.4: CLOCK_27 is sourced from the TV Decoder
# ADV7180. Two requirements to keep that signal valid:
#   1. TD_RESET (PIN_C4) must be driven HIGH so the decoder isn't
#      held in reset (otherwise it doesn't generate the 27 MHz
#      clock). Wired in riski5_top.v as a top-level output set to
#      logic 1.
#   2. TD_CLK27 (PIN_C16, the alternate copy of the same 27 MHz
#      clock) must be assigned (or set to "AS input tri-stated"
#      via the unused-pin policy) so the FPGA doesn't put the pad
#      into a state that disturbs the TV decoder's clock generation
#      circuit. We tie it to a top-level input named TD_CLK27 in
#      the wrapper but never read it; Quartus places the pin and
#      leaves it floating into the design.
set_location_assignment PIN_C4 -to TD_RESET
set_instance_assignment -name IO_STANDARD "3.3-V LVTTL" -to TD_RESET
set_location_assignment PIN_C16 -to TD_CLK27
set_instance_assignment -name IO_STANDARD "3.3-V LVTTL" -to TD_CLK27

# -- Pushbuttons KEY[3:0] ------------------------------------------
# KEY[0] is the async active-LOW reset (gated against PLL lock to
# form rstBus_n in riski5_top.v). KEY[1..3] are general buttons the
# core can read. All four are active-LOW on the DE2.
set_location_assignment PIN_G26 -to KEY[0]
set_location_assignment PIN_N23 -to KEY[1]
set_location_assignment PIN_P23 -to KEY[2]
set_location_assignment PIN_W26 -to KEY[3]
set_instance_assignment -name IO_STANDARD "3.3-V LVTTL" -to KEY[0]
set_instance_assignment -name IO_STANDARD "3.3-V LVTTL" -to KEY[1]
set_instance_assignment -name IO_STANDARD "3.3-V LVTTL" -to KEY[2]
set_instance_assignment -name IO_STANDARD "3.3-V LVTTL" -to KEY[3]

# -- Slide switches SW[17:0] ---------------------------------------
set_location_assignment PIN_N25  -to SW[0]
set_location_assignment PIN_N26  -to SW[1]
