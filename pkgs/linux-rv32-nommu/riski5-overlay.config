# SPDX-FileCopyrightText: 2026 Mika Tammi
# SPDX-License-Identifier: GPL-2.0
#
# Linux kernel config overlay for the riski5 SoC. Layered on top
# of nommu_virt_defconfig + arch/riscv/configs/32-bit.config (in
# that order). See pkgs/linux-rv32-nommu/package.nix for the
# build sequence.
#
# == Why each line
#
# CMDLINE: bootargs come from the kernel-builtin string instead of
#   the device-tree's chosen.bootargs. Both work for nommu boot;
#   builtin is one less moving piece to debug. Override at runtime
#   via `_EXTEND` if a future bootloader wants to append.
#
# Altera JTAG-UART driver: in-tree since 2.6.36
#   (drivers/tty/serial/altera_jtaguart.c). DT compatible
#   "altr,juart-1.0" — matches our riski5.dts.
#
# Size cuts: nommu boots are tight on 8 MB SDRAM. Drop everything
#   not needed for "Linux is alive and printing on the UART".
#   Networking, USB, MMC, block layer, framebuffer, sound, etc. all
#   come back when the corresponding hardware path lands (none of
#   them do in phase-2A). CC_OPTIMIZE_FOR_SIZE makes the .text
#   section ~10 % smaller for our minimal config.
#
# RISCV_ISA_C disabled because riski5 doesn't yet have a C-extension
#   silicon bring-up (RV32C decoder is in sim only — see
#   docs/core-family.md and TODO.md task #111).

# === Boot args ===
# The earlycon name must be "juart" — that's the name Linux's
# altera_jtaguart driver registers via OF_EARLYCON_DECLARE
# (drivers/tty/serial/altera_jtaguart.c). An earlier "jtag-uart"
# string here was never matched by Linux's earlycon parser, which
# is why kernel boot was completely silent before any printk
# emission ever reached the JTAG-UART TX FIFO.
#
# loglevel=8 (KERN_DEBUG) + ignore_loglevel + debug pull every
# pr_debug() onto the wire — useful while we're still figuring
# out where head.S stops or hangs on this SoC.
CONFIG_CMDLINE_BOOL=y
CONFIG_CMDLINE_EXTEND=y
# CONFIG_CMDLINE_FORCE is not set
CONFIG_CMDLINE="console=ttyJ0 earlycon=juart,mmio,0x10000000 keep_bootcon loglevel=8 ignore_loglevel debug rdinit=/init"

# === ISA shape ===
# riski5 currently implements RV32I + M + A (atomics) + Zicsr +
# Zifencei. Everything else gets a trap-on-illegal in the core,
# which will mtvec back to BRAM[0] (the boot stub) under our
# current config. Turn each off here so the kernel doesn't
# probe-then-trap during early head.S boot — those probes
# happen before earlycon is alive, so the trap just stops the
# kernel silently.
# CONFIG_RISCV_ISA_C is not set
# CONFIG_RISCV_ISA_V is not set
# CONFIG_RISCV_ISA_V_DEFAULT_ENABLE is not set
# CONFIG_RISCV_ISA_ZAWRS is not set
# CONFIG_RISCV_ISA_ZACAS is not set
# CONFIG_RISCV_ISA_ZBA is not set
# CONFIG_RISCV_ISA_ZBB is not set
# CONFIG_RISCV_ISA_ZBKB is not set
# CONFIG_RISCV_ISA_ZICBOZ is not set
# CONFIG_RISCV_ISA_ZICBOM is not set
# CONFIG_RISCV_MISALIGNED is not set
# CONFIG_RISCV_SCALAR_MISALIGNED is not set
# CONFIG_RISCV_VECTOR_MISALIGNED is not set
# CONFIG_RISCV_PROBE_UNALIGNED_ACCESS is not set

# === Console driver ===
CONFIG_SERIAL_ALTERA_JTAGUART=y
CONFIG_SERIAL_ALTERA_JTAGUART_CONSOLE=y

# === Aggressive size cuts ===
# CONFIG_DEBUG_INFO is not set
# CONFIG_DEBUG_KERNEL is not set
# CONFIG_KALLSYMS is not set
# CONFIG_NET is not set
# CONFIG_SOUND is not set
# CONFIG_USB_SUPPORT is not set
# CONFIG_MMC is not set
# CONFIG_INPUT is not set
# CONFIG_VT is not set
# CONFIG_DRM is not set
# CONFIG_FB is not set
# CONFIG_BLOCK is not set
# CONFIG_VIRTIO_BLK is not set
# CONFIG_VIRTIO_NET is not set
# CONFIG_VIRTIO_MMIO is not set
CONFIG_CC_OPTIMIZE_FOR_SIZE=y

# === PLIC + CLINT bind ===
CONFIG_SIFIVE_PLIC=y
CONFIG_RISCV_TIMER=y

# === Initramfs ===
# Embed the cpio in vmlinux at link time. The L-7 build passes
# the cpio path here via a kbuild override.
CONFIG_INITRAMFS_SOURCE=""
