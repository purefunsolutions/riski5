From: Mika Tammi <mikatammi@gmail.com>
Subject: [DEBUG] add early_printk to __schedule + completion paths for #64

Trace what kthreadd / kernel_init are doing during the silent
post-Mountpoint-cache hang on the riski5 SoC. Sprinkles
early_printk()-equivalent calls at the entry of:

  - __schedule (every call — tells us the exact cycle)
  - kthreadd's main loop iterations
  - wait_for_completion / complete (so we know who's blocking on what)

Uses pr_emerg("DBG: ...") at KERN_EMERG so the line bypasses any
loglevel filter and goes straight to the JTAG-UART earlycon.

Apply in pkgs/linux-rv32-nommu/package.nix's prePatch hook.

Signed-off-by: Mika Tammi <mikatammi@gmail.com>
---
 init/main.c          | 4 ++++
 kernel/kthread.c     | 6 ++++++
 kernel/sched/core.c  | 4 ++++
 kernel/sched/completion.c | 6 ++++++
 4 files changed, 20 insertions(+)

diff --git a/init/main.c b/init/main.c
--- a/init/main.c
+++ b/init/main.c
@@ -1416,6 +1416,7 @@ noinline void __ref __noreturn rest_init(void)
 {
 	struct task_struct *tsk;
 	int pid;
+	pr_emerg("DBG: rest_init entered\n");

 	rcu_scheduler_starting();
 	/*
@@ -1517,6 +1518,7 @@ static noinline void __init kernel_init_freeable(void)

 	cad_pid = get_pid(task_pid(current));

+	pr_emerg("DBG: kernel_init_freeable entered\n");
 	smp_prepare_cpus(setup_max_cpus);

 	workqueue_init();
@@ -1606,6 +1608,7 @@ static int __ref kernel_init(void *unused)

 	wait_for_completion(&kthreadd_done);

+	pr_emerg("DBG: kernel_init: kthreadd_done complete; calling kernel_init_freeable\n");
 	kernel_init_freeable();
 	/* need to finish all async __init code before freeing the memory */
 	async_synchronize_full();
diff --git a/kernel/kthread.c b/kernel/kthread.c
--- a/kernel/kthread.c
+++ b/kernel/kthread.c
@@ -752,6 +752,7 @@ int kthreadd(void *unused)
 	for (;;) {
 		set_current_state(TASK_INTERRUPTIBLE);
 		if (list_empty(&kthread_create_list))
+			pr_emerg("DBG: kthreadd loop top, list empty, scheduling out\n"),
 			schedule();
 		__set_current_state(TASK_RUNNING);

@@ -763,6 +764,7 @@ int kthreadd(void *unused)
 			list_del_init(&create->list);
 			spin_unlock(&kthread_create_lock);

+			pr_emerg("DBG: kthreadd processing create request\n");
 			create_kthread(create);

 			spin_lock(&kthread_create_lock);
diff --git a/kernel/sched/completion.c b/kernel/sched/completion.c
--- a/kernel/sched/completion.c
+++ b/kernel/sched/completion.c
@@ -78,6 +78,7 @@ EXPORT_SYMBOL(complete);
  */
 void complete_all(struct completion *x)
 {
+	pr_emerg("DBG: complete_all called\n");
 	unsigned long flags;

 	lockdep_assert_RT_in_threaded_ctx();
@@ -130,6 +131,7 @@ wait_for_completion_state(struct completion *x, unsigned int state)
 void __sched wait_for_completion(struct completion *x)
 {
 	wait_for_common(x, MAX_SCHEDULE_TIMEOUT, TASK_UNINTERRUPTIBLE);
+	pr_emerg("DBG: wait_for_completion returning\n");
 }
 EXPORT_SYMBOL(wait_for_completion);
