# Nix build outputs
result
result-*

# Claude-local state
.claude/

# Haskell / cabal
dist/
dist-newstyle/
.ghc.environment.*
*.hi
*.o
cabal.project.local
cabal.project.local~

# Firmware emit artefacts. The canonical .mif is produced by the
# Nix build under result/; anything at the repo root is a local
# dev run of `cabal run riski5-emit-hello`.
/hello.mif

# Quartus / Verilator / simulation artefacts
*.vcd
*.fst
output_files/
db/
incremental_db/
obj_dir/
greybox_tmp/

# hwsim debug logs and UART captures from local boot runs.
.hwsim*.log
.hwsim*.bin
riski5-linux-hwsim.uart.bin

# Local benchmark build dirs (one per O2/O3 × NCG/LLVM matrix from #63).
dist-bench-*/

# Only commit PDFs under docs/riscv/ and docs/de2/ that the plan explicitly
# names. Stray downloads stay out.
docs/**/*.pdf
!docs/riscv/*.pdf
!docs/de2/*.pdf
verilog/
