+  -- Three-tier forwarding, by producer age (newest wins):
+  --   EX→X   — one ahead of X, sitting in EX/MEM right now; its
+  --            computed result is fresh and hasn't hit the regfile
+  --            yet.
+  --   MEM→X  — two ahead of X, in MEM/WB; same story, one stage
+  --            further along. Only fires if EX→X didn't match.
+  --   W-1→X  — three ahead of X: committed __at the clock edge
+  --            leading into this cycle__ (one cycle ago it was in
+  --            MEM/WB, now retired). Its write landed in the
+  --            blockRam at that edge, but the read port's output
+  --            this cycle still reflects pre-edge memory
+  --            (read-first semantics), so we bypass from the held
+  --            copy in 'wbHoldS'. With async regfileAsync this
+  --            tier was unnecessary — writes were visible on the
+  --            same cycle they were applied because reads went
+  --            through a combinational mux over the 'register'
+  --            that already holds the new value. blockRamPow2's
+  --            read-first semantics force this extra bypass.
+  forwardRs ::
+    BitVector 5 ->
+    BitVector 32 ->
+    ExMem ->
+    MemWb ->
+    Maybe (BitVector 5, BitVector 32) ->
+    BitVector 32
+  forwardRs rsAddr rsData exM mwM wbH
     | rsAddr == 0 = 0
     | emValid exM && emWbEn exM && emRd exM == rsAddr = emWbData exM
     | mwValid mwM && mwWbEn mwM && mwRd mwM == rsAddr = mwWbData mwM
+    | Just (r, v) <- wbH, r == rsAddr = v
     | otherwise = rsData
 
